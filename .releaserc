{
	"branches": [
		{
			"name": "main",
			"channel": "latest"
		}
	],
	"plugins": [
		[
			"@semantic-release/commit-analyzer",
			{
				"preset": "angular",
				"releaseRules": [
					{
						"breaking": true,
						"release": "major"
					},
					{
						"revert": true,
						"release": "patch"
					},
					{
						"type": "feat",
						"release": "minor"
					},
					{
						"type": "fix",
						"release": "patch"
					},
					{
						"type": "perf",
						"release": "patch"
					},
					{
						"emoji": ":racehorse:",
						"release": "patch"
					},
					{
						"emoji": ":bug:",
						"release": "patch"
					},
					{
						"emoji": ":penguin:",
						"release": "patch"
					},
					{
						"emoji": ":apple:",
						"release": "patch"
					},
					{
						"emoji": ":checkered_flag:",
						"release": "patch"
					},
					{
						"tag": "BUGFIX",
						"release": "patch"
					},
					{
						"tag": "FEATURE",
						"release": "minor"
					},
					{
						"tag": "SECURITY",
						"release": "patch"
					},
					{
						"tag": "Breaking",
						"release": "major"
					},
					{
						"tag": "Fix",
						"release": "patch"
					},
					{
						"tag": "Update",
						"release": "minor"
					},
					{
						"tag": "New",
						"release": "minor"
					},
					{
						"component": "perf",
						"release": "patch"
					},
					{
						"component": "deps",
						"release": "patch"
					},
					{
						"type": "FEAT",
						"release": "minor"
					},
					{
						"type": "FIX",
						"release": "patch"
					},
					{
						"type": "*",
						"release": "patch"
					},
					{
						"tag": "*",
						"release": "patch"
					},
					{
						"subject": "*",
						"release": "patch"
					},
					{
						"body": "*",
						"release": "patch"
					},
					{
						"message": "*",
						"release": "patch"
					}
				]
			}
		],
		"@semantic-release/release-notes-generator",
		[
			"@semantic-release/changelog",
			{
				"changelogFile": "CHANGELOG.md",
				"changelogTitle": "# Changelog"
			}
		],
		[
			"@semantic-release/npm",
			{
				"pkgRoot": "dist"
			}
		],
		[
			"@semantic-release/git",
			{
				"assets": [
					"package.json",
					"CHANGELOG.md"
				],
				"message": "chore(release): <%= nextRelease.version %> [skip ci] \n\n<%= nextRelease.notes %>"
			}
		]
	]
}
